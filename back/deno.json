{
	"tasks": {
		"bc-dev": "ENV=development deno run -A --watch --watch-exclude=declarations --no-clear-screen ./mod.ts"
	},
	"fmt": {
		"files": {
			"exclude": ["declaration"]
		},
		"options": {
			"useTabs": true,
			"lineWidth": 80,
			"indentWidth": 4,
			"semiColons": true,
			"proseWrap": "preserve"
		}
	},
	"imports": {
		"@deps": "./deps.ts",
		"@lib": "./utils/mod.ts",
		"@model": "./models/mod.ts",
		"node-unrar-js": "npm:node-unrar-js@2.0.2"
	},
	"nodeModulesDir": "auto"
}
